# Copy this file to .env and fill in your actual values. Never commit .env to git.

GOOGLE_API_KEY=your_gemini_api_key_here

# Model config per node (see agents/config.py for how these are used)
PLANNER_MODEL=gemini-1.5-flash
RESEARCH_MODEL=gemini-1.5-flash
SYNTHESIS_MODEL=gemini-1.5-pro
CRITIQUE_MODEL=gemini-1.5-flash

# Database
DATABASE_URL=sqlite:///./rune.db

# Web search (optional - plug in your preferred search API)
SEARCH_API_KEY=your_search_api_key_here

# Server
PORT=8000
MAX_CRITIQUE_ITERATIONS=2
